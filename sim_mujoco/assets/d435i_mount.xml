<mujoco model="d435i_mount">
  <!-- RealSense D435i camera mount for LeKiwi.
       Sitting on the camera_mount site of lekiwi_base.
       Provides a camera-frustum visual and sites for ray origins. -->

  <default>
    <geom type="box" density="200"/>
  </default>

  <worldbody>
    <body name="d435i_body" pos="0.10 0 0.08" euler="0 -15 0">
      <!-- Camera housing -->
      <geom name="camera_housing" type="box" size="0.045 0.012 0.012"
            pos="0.01 0 0" rgba="0.15 0.15 0.15 1" mass="0.05"/>

      <!-- Left IR sensor -->
      <geom name="ir_left" type="cylinder" size="0.004 0.006"
            pos="0.025 0.025 0" rgba="0.1 0.1 0.1 1" mass="0.005"/>
      <!-- Right IR sensor -->
      <geom name="ir_right" type="cylinder" size="0.004 0.006"
            pos="0.025 -0.025 0" rgba="0.1 0.1 0.1 1" mass="0.005"/>
      <!-- RGB sensor center -->
      <geom name="rgb_sensor" type="cylinder" size="0.006 0.008"
            pos="0.03 0 0" rgba="0.05 0.05 0.05 1" mass="0.005"/>

      <!-- Ray origin sites -->
      <site name="ray_origin" pos="0.035 0 0" size="0.003"/>
    </body>
  </worldbody>
</mujoco>
